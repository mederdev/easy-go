# ── Postgres ───────────────────────────────────────────────
POSTGRES_USER=easygo
POSTGRES_PASSWORD=easygo
POSTGRES_DB=easygo
# Used by the API (Prisma). Host is "postgres" inside Docker, "localhost" from host.
DATABASE_URL=postgresql://easygo:easygo@localhost:5432/easygo?schema=public

# ── Redis (BullMQ + rate limit) ────────────────────────────
REDIS_URL=redis://localhost:6379

# ── MinIO (S3-compatible object storage) ───────────────────
MINIO_ROOT_USER=easygo
MINIO_ROOT_PASSWORD=easygo-secret
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_BUCKET=easygo

# ── API ────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=3000
NODE_ENV=development
# Change in production. Used to sign JWTs.
JWT_SECRET=dev-insecure-change-me
JWT_EXPIRES_IN=7d
# CORS origins for admin + client dev servers
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:8100

# ── Telegram Login Widget (customer auth) ──────────────────
# Bot token from @BotFather — verifies the widget `hash` server-side.
# Leave empty in dev to bypass verification (NODE_ENV != production).
TELEGRAM_BOT_TOKEN=
# Bot username (without @). Also set VITE_TELEGRAM_BOT_USERNAME below for the widget.
# Remember to run /setdomain in @BotFather for the domain hosting the client app.
TELEGRAM_BOT_USERNAME=

# ── Front-end build-time config ────────────────────────────
VITE_API_URL=http://localhost:3000
# 2GIS map widget key (https://dev.2gis.com)
VITE_2GIS_KEY=
# Telegram bot username (without @) for the "Login with Telegram" widget.
VITE_TELEGRAM_BOT_USERNAME=
