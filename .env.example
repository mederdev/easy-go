# ── Postgres ───────────────────────────────────────────────
POSTGRES_USER=easygo
POSTGRES_PASSWORD=easygo
POSTGRES_DB=easygo
# Used by the API (Prisma). Host is "postgres" inside Docker, "localhost" from host.
DATABASE_URL=postgresql://easygo:easygo@localhost:5432/easygo?schema=public

# ── Redis (BullMQ + rate limit) ────────────────────────────
REDIS_URL=redis://localhost:6379

# ── MinIO (S3-compatible object storage) ───────────────────
MINIO_ROOT_USER=easygo
MINIO_ROOT_PASSWORD=easygo-secret
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_BUCKET=easygo

# ── API ────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=3000
NODE_ENV=development
# Change in production. Used to sign JWTs.
JWT_SECRET=dev-insecure-change-me
JWT_EXPIRES_IN=7d
# CORS origins for admin + client dev servers
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:8100

# ── Telegram bot (auth + notifications) ────────────────────
# Bot token from @BotFather. Powers the deep-link login/registration
# (t.me/<bot>?start=…, works on BOTH domains — no /setdomain needed) and
# booking notifications to admins. Leave empty in dev: the bot poller stays
# off, Telegram sends are console-mocked, and login screens show a
# "Подтвердить (dev)" button instead.
TELEGRAM_BOT_TOKEN=
# Bot username (without @) — used to build the t.me deep links server-side.
TELEGRAM_BOT_USERNAME=

# ── Front-end build-time config ────────────────────────────
VITE_API_URL=http://localhost:3000
# 2GIS map widget key (https://dev.2gis.com)
VITE_2GIS_KEY=
# Optional render hint: shows the Telegram login block in prod client builds.
# The deep link itself is built by the API from TELEGRAM_BOT_USERNAME.
VITE_TELEGRAM_BOT_USERNAME=
