# ─────────────────────────────────────────────────────────────────────────
# EasyGo PRODUCTION env — copy to `.env.prod` on the server and fill real
# values, then `chmod 600 .env.prod`. NEVER commit the real file.
#
# This single file is used two ways, so it must live next to the compose file:
#   • docker compose ${interpolation}  (image tags, postgres/minio creds)
#   • injected into the api/migrate containers via `env_file:`
#
# Always run compose as:
#   docker compose --env-file .env.prod -f docker-compose.prod.yml <cmd>
# ─────────────────────────────────────────────────────────────────────────

# ── GHCR image coordinates ──
GHCR_OWNER=mederdev     # lowercase owner in ghcr.io/<owner>/easygo-*
TAG=latest                        # CI overrides this per-deploy with the commit SHA

# ── Postgres ──
POSTGRES_USER=easygo
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=easygo

# ── API runtime ──
NODE_ENV=production
API_HOST=0.0.0.0
API_PORT=3000
# Password here MUST match POSTGRES_PASSWORD above; host is the compose service.
DATABASE_URL=postgresql://easygo:change-me-strong-db-password@postgres:5432/easygo?schema=public
REDIS_URL=redis://redis:6379
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d
# Exact https origins of the SPAs (credentials are sent, so no wildcard).
CORS_ORIGINS=https://easygo-transfer.com,https://www.easygo-transfer.com,https://admin.easygo-transfer.com

# ── Telegram bot (auth + notifications) ──
# Bot token from @BotFather. Powers the deep-link login/registration on BOTH
# domains (client + admin — no /setdomain needed) and booking notifications
# (add the bot to the ops group — the chat id is captured automatically).
TELEGRAM_BOT_TOKEN=change-me-telegram-bot-token
# Bot username (without @) — the API builds t.me deep links from it.
TELEGRAM_BOT_USERNAME=EasyGoBot

# ── MinIO / object storage ──
MINIO_ROOT_USER=easygo
MINIO_ROOT_PASSWORD=change-me-strong-minio-password
MINIO_BUCKET=easygo
MINIO_REGION=us-east-1
# Internal endpoint — how the API container reaches MinIO (inside the network).
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
# Public endpoint — what the browser uses for presigned URLs (proxied by edge).
MINIO_PUBLIC_ENDPOINT=storage.easygo-transfer.com
MINIO_PUBLIC_PORT=443
MINIO_PUBLIC_USE_SSL=true
# Origins allowed to call MinIO directly from the browser (CORS preflight).
MINIO_API_CORS_ALLOW_ORIGIN=https://easygo-transfer.com,https://www.easygo-transfer.com,https://admin.easygo-transfer.com
