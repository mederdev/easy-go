// EasyGo data model. Money = integer minor units. Counters denormalized.
// Mirrors the ER diagram in "EasyGo Architecture.dc.html".

generator client {
  provider      = "prisma-client-js"
  // "native" for local dev; the musl/openssl-3 target is for the Alpine image.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  operator
  admin
  owner
}

enum BookingStatus {
  NEW
  CONFIRMED
  COMPLETED
  CANCELLED
  CANCELLED_BY_CLIENT
  CANCELLED_BY_COMPANY
}

enum FlightStatus {
  SCHEDULED
  CLOSED
  DEPARTED
  COMPLETED
  CANCELLED
  CANCELLED_BY_CLIENT
  CANCELLED_BY_COMPANY
}

enum RouteStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

/// Payment state of a booking (from prepaid vs total) or a flight (aggregated).
enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum CarStatus {
  AVAILABLE
  ON_TRIP
  MAINTENANCE
}

enum ApplicationStatus {
  NEW
  REVIEWING
  ACCEPTED
  REJECTED
}

enum FileOwnerType {
  CAR
  COMPANY
  DRIVER_APPLICATION
  PARTNER_APPLICATION
}

enum FileKind {
  CAR_PHOTO
  COMPANY_PHOTO
  LICENSE
  ATTACHMENT
}

enum CurrencyCode {
  KGS
  KZT
  USD
  RUB
}

/// Back-office users (operator / admin / owner).
model User {
  id           String   @id @default(uuid())
  name         String
  phone        String   @unique
  role         UserRole @default(operator)
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// Booking customer. Upserted by phone from the public booking flow.
model Client {
  id            String    @id @default(uuid())
  name          String
  phone         String    @unique
  whatsapp      Boolean   @default(true)
  passwordHash  String?
  passwordRaw   String?   // plain-text copy for admin display
  tripsCount    Int       @default(0) // denormalized
  totalSum      Int       @default(0) // denormalized, minor units
  lastBookingAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  bookings Booking[]

  @@index([name])
}

model Driver {
  id           String   @id @default(uuid())
  name         String
  phone        String   @unique
  passwordHash String?
  passwordRaw  String?  // plain-text copy for admin display
  experience   String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  cars Car[]
}

model Car {
  id           String    @id @default(uuid())
  model        String
  plate        String    @unique
  driverId     String?
  driver       Driver?   @relation(fields: [driverId], references: [id], onDelete: SetNull)
  seats        Int       @default(11)
  status       CarStatus @default(AVAILABLE)
  locationCity String?
  currentLat   Float?
  currentLng   Float?
  tripsMonth   Int       @default(0) // denormalized
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  flights Flight[]

  @@index([status])
}

model Route {
  id            String      @id @default(uuid())
  fromCity      String
  toCity        String
  durationLabel String
  price         Int // minor units, per seat
  dailyTrips    Int         @default(0)
  status        RouteStatus @default(ACTIVE)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  flights    Flight[]
  dailyStats DailyStat[]

  @@unique([fromCity, toCity])
  @@index([status])
}

model Flight {
  id            String       @id @default(uuid())
  routeId       String
  route         Route        @relation(fields: [routeId], references: [id], onDelete: Restrict)
  carId         String?
  car           Car?         @relation(fields: [carId], references: [id], onDelete: SetNull)
  departAt      DateTime
  pickupLat     Float?
  pickupLng     Float?
  pickupAddress String?
  seatsTotal    Int          @default(11)
  seatsTaken    Int          @default(0) // denormalized
  status        FlightStatus @default(SCHEDULED)
  paymentStatus PaymentStatus @default(UNPAID) // aggregated from active bookings
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  bookings Booking[]

  @@index([routeId, departAt])
  @@index([departAt])
  @@index([status])
}

model Booking {
  id             String        @id @default(uuid())
  seq            Int           @unique @default(autoincrement())
  code           String        @unique
  clientId       String
  client         Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  flightId       String
  flight         Flight        @relation(fields: [flightId], references: [id], onDelete: Restrict)
  pax            Int
  discount       Int           @default(0) // minor units, amount off
  prepaid        Int           @default(0) // minor units, paid so far
  total          Int // minor units = price * pax - discount
  status         BookingStatus @default(NEW)
  paymentStatus  PaymentStatus @default(UNPAID)
  comment        String?
  idempotencyKey String?       @unique
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([status])
  @@index([clientId])
  @@index([flightId])
  @@index([createdAt])
}

/// Precomputed per-route, per-day analytics (source for all dashboards).
model DailyStat {
  id                String   @id @default(uuid())
  date              DateTime @db.Date
  routeId           String?
  route             Route?   @relation(fields: [routeId], references: [id], onDelete: SetNull)
  ordersCount       Int      @default(0)
  revenue           Int      @default(0) // minor units
  newClients        Int      @default(0)
  returningClients  Int      @default(0)

  @@unique([date, routeId])
  @@index([date])
}

model DriverApplication {
  id         String            @id @default(uuid())
  name       String
  phone      String
  hasCar     Boolean           @default(false)
  carInfo    String?
  experience String?
  directions String?
  about      String?
  status     ApplicationStatus @default(NEW)
  createdAt  DateTime          @default(now())

  @@index([status])
}

model PartnerApplication {
  id        String            @id @default(uuid())
  company   String
  sphere    String?
  contacts  String
  proposal  String?
  status    ApplicationStatus @default(NEW)
  createdAt DateTime          @default(now())

  @@index([status])
}

model FileObject {
  id          String        @id @default(uuid())
  ownerType   FileOwnerType
  ownerId     String
  bucket      String
  key         String
  kind        FileKind
  contentType String
  size        Int           @default(0)
  createdAt   DateTime      @default(now())

  @@index([ownerType, ownerId])
}

/// Individual trip request left by a customer when no suitable flight exists.
model CustomRequest {
  id        String            @id @default(uuid())
  fromCity  String
  toCity    String
  date      String            // YYYY-MM-DD desired departure
  pax       Int
  phone     String
  comment   String?
  status    ApplicationStatus @default(NEW)
  createdAt DateTime          @default(now())

  @@index([status])
  @@index([createdAt])
}

/// Generic idempotency store powering the Idempotency-Key plugin.
model IdempotencyKey {
  key         String   @id
  endpoint    String
  requestHash String
  response    Json
  statusCode  Int      @default(200)
  createdAt   DateTime @default(now())
}

/// Singleton system settings (id is always "singleton").
model SystemConfig {
  id            String       @id @default("singleton")
  currency      CurrencyCode @default(KGS)
  companyName   String       @default("EasyGo")
  whatsappPhone String       @default("996700123456")
  locale        String       @default("ru-RU")
  updatedAt     DateTime     @updatedAt
}
