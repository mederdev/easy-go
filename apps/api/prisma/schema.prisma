// EasyGo data model. Money = integer minor units. Counters denormalized.
// Mirrors the ER diagram in "EasyGo Architecture.dc.html".

generator client {
  provider      = "prisma-client-js"
  // "native" for local dev; the musl/openssl-3 target is for the Alpine image.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  operator
  admin
  owner
}

enum BookingStatus {
  NEW
  CONFIRMED
  COMPLETED
  CANCELLED
  CANCELLED_BY_CLIENT
  CANCELLED_BY_COMPANY
}

enum CarFeature {
  ROOF_RACK
  CHILD_SEAT
  EXTRA_LUGGAGE
  PET
}

enum FlightStatus {
  SCHEDULED
  CLOSED
  DEPARTED
  COMPLETED
  CANCELLED
  CANCELLED_BY_CLIENT
  CANCELLED_BY_COMPANY
}

enum RouteStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

/// Payment state of a booking (from prepaid vs total) or a flight (aggregated).
enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

/// A pickup/dropoff point on a booking: where the driver collects or drops a passenger.
enum StopKind {
  PICKUP
  DROPOFF
}

/// Lifecycle of a catalog service add-on. Archived rows stay referenced by past
/// bookings but drop out of the pick-list; there is no hard delete.
enum AddonStatus {
  ACTIVE
  ARCHIVED
}

enum CarType {
  SEDAN
  MINIVAN
  BUS
}

enum CarStatus {
  AVAILABLE
  ON_TRIP
  MAINTENANCE
}

enum ApplicationStatus {
  NEW
  REVIEWING
  ACCEPTED
  REJECTED
}

enum FileOwnerType {
  CAR
  COMPANY
  DRIVER_APPLICATION
  PARTNER_APPLICATION
}

enum FileKind {
  CAR_PHOTO
  COMPANY_PHOTO
  LICENSE
  ATTACHMENT
}

enum CurrencyCode {
  KGS
  KZT
  USD
  RUB
}

/// Back-office users (operator / admin / owner).
model User {
  id               String   @id @default(uuid())
  name             String
  phone            String   @unique
  role             UserRole @default(operator)
  telegramId       String?  @unique // linked Telegram account: bot login + booking notifications
  telegramUsername String?
  passwordHash     String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

/// Booking customer. Upserted by phone from the public booking flow, or created
/// via the Telegram Login Widget (no phone until they provide one at booking).
model Client {
  id               String    @id @default(uuid())
  name             String
  phone            String?   @unique // nullable: Telegram signups have no phone yet
  whatsapp         Boolean   @default(true)
  telegramId       String?   @unique // Telegram Login Widget user id
  telegramUsername String?
  photoUrl         String? // Telegram avatar
  passwordHash     String?
  passwordRaw      String? // plain-text copy for admin display
  tripsCount       Int       @default(0) // denormalized
  totalSum         Int       @default(0) // denormalized, minor units
  lastBookingAt    DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  bookings Booking[]

  @@index([name])
}

model Driver {
  id           String   @id @default(uuid())
  name         String
  phone        String   @unique
  passwordHash String?
  passwordRaw  String? // plain-text copy for admin display
  experience   String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  cars Car[]
}

model Car {
  id           String    @id @default(uuid())
  model        String
  plate        String    @unique
  type         CarType   @default(MINIVAN)
  features     CarFeature[] // extra capabilities (roof rack, child seat…)
  driverId     String?
  driver       Driver?   @relation(fields: [driverId], references: [id], onDelete: SetNull)
  seats        Int       @default(11)
  status       CarStatus @default(AVAILABLE)
  locationCity String?
  currentLat   Float?
  currentLng   Float?
  tripsMonth   Int       @default(0) // denormalized
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  flights Flight[]

  @@index([status])
}

model Route {
  id            String      @id @default(uuid())
  fromCity      String
  toCity        String
  durationLabel String
  price         Int // minor units, per seat
  dailyTrips    Int         @default(0)
  status        RouteStatus @default(ACTIVE)
  popular       Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  flights    Flight[]
  dailyStats DailyStat[]

  @@unique([fromCity, toCity])
  @@index([status])
}

model Flight {
  id            String        @id @default(uuid())
  routeId       String
  route         Route         @relation(fields: [routeId], references: [id], onDelete: Restrict)
  carId         String?
  car           Car?          @relation(fields: [carId], references: [id], onDelete: SetNull)
  departAt      DateTime
  pickupLat     Float?
  pickupLng     Float?
  pickupAddress String?
  dropoffAddress String?
  seatsTotal    Int           @default(11)
  seatsTaken    Int           @default(0) // denormalized
  status        FlightStatus  @default(SCHEDULED)
  paymentStatus PaymentStatus @default(UNPAID) // aggregated from active bookings
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  bookings Booking[]

  @@index([routeId, departAt])
  @@index([departAt])
  @@index([status])
}

model Booking {
  id             String        @id @default(uuid())
  seq            Int           @unique @default(autoincrement())
  code           String        @unique
  clientId       String
  client         Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  flightId       String
  flight         Flight        @relation(fields: [flightId], references: [id], onDelete: Restrict)
  pax            Int
  unitPrice      Int? // minor units, per-seat price override; null = use route.price
  discount       Int           @default(0) // minor units, amount off
  prepaid        Int           @default(0) // minor units, paid so far
  total          Int // minor units = (unitPrice ?? route.price) * pax - discount
  status         BookingStatus @default(NEW)
  paymentStatus  PaymentStatus @default(UNPAID)
  comment        String?
  idempotencyKey String?       @unique
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  stops  BookingStop[]
  addons BookingAddon[]

  @@index([status])
  @@index([clientId])
  @@index([flightId])
  @@index([createdAt])
}

/// Extra pickup/dropoff point on a booking. The client adds/edits addresses;
/// the price is per-point, set (confirmed) by an admin — null until then.
/// `pickedUp` is the driver's "collected this passenger here" checkbox.
model BookingStop {
  id        String   @id @default(uuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  kind      StopKind @default(PICKUP)
  address   String
  note      String?
  price     Int? // minor units; null = not yet confirmed by admin
  pickedUp  Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookingId])
}

/// Reusable catalog of paid extra services (детское кресло, встреча с табличкой…).
/// An admin manages these; each has a default price (minor units). Attaching one
/// to a booking snapshots its name+price into a BookingAddon, so later catalog
/// edits never rewrite historical booking totals. Soft-deleted via ARCHIVED.
model ServiceAddon {
  id        String         @id @default(uuid())
  name      String
  price     Int            @default(0) // default price, minor units
  status    AddonStatus    @default(ACTIVE)
  order     Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  lines     BookingAddon[]

  @@index([status])
}

/// A paid extra service attached to a booking. name+price are snapshots taken
/// when it was attached (the catalog row is just a template); the price folds
/// into `booking.total` alongside seats and confirmed stops. `addonId` goes null
/// if the catalog row is later archived-then-removed, but the line survives.
model BookingAddon {
  id        String        @id @default(uuid())
  bookingId String
  booking   Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  addonId   String?
  addon     ServiceAddon? @relation(fields: [addonId], references: [id], onDelete: SetNull)
  name      String // snapshot at attach time
  price     Int           @default(0) // snapshot, minor units — part of booking.total
  order     Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([bookingId])
}

/// Precomputed per-route, per-day analytics (source for all dashboards).
model DailyStat {
  id               String   @id @default(uuid())
  date             DateTime @db.Date
  routeId          String?
  route            Route?   @relation(fields: [routeId], references: [id], onDelete: SetNull)
  ordersCount      Int      @default(0)
  revenue          Int      @default(0) // minor units
  newClients       Int      @default(0)
  returningClients Int      @default(0)

  @@unique([date, routeId])
  @@index([date])
}

model DriverApplication {
  id         String            @id @default(uuid())
  name       String
  phone      String
  hasCar     Boolean           @default(false)
  carInfo    String?
  experience String?
  directions String?
  about      String?
  status     ApplicationStatus @default(NEW)
  createdAt  DateTime          @default(now())

  @@index([status])
}

model PartnerApplication {
  id        String            @id @default(uuid())
  company   String
  sphere    String?
  contacts  String
  proposal  String?
  status    ApplicationStatus @default(NEW)
  createdAt DateTime          @default(now())

  @@index([status])
}

model FileObject {
  id          String        @id @default(uuid())
  ownerType   FileOwnerType
  ownerId     String
  bucket      String
  key         String
  kind        FileKind
  contentType String
  size        Int           @default(0)
  createdAt   DateTime      @default(now())

  @@index([ownerType, ownerId])
}

/// Individual trip request left by a customer when no suitable flight exists.
model CustomRequest {
  id         String            @id @default(uuid())
  fromCity   String
  toCity     String
  date       String // YYYY-MM-DD desired departure
  time       String? // "HH:MM" desired departure time (null = no preference)
  pax        Int
  carType    CarType? // desired vehicle class (null = no preference)
  features   CarFeature[] // desired add-ons (roof rack, child seat…)
  wholeCabin Boolean           @default(false) // "салон" — book the entire car
  stops      Json              @default("[]") // [{kind, address, note, price}] — desired pickup/dropoff points (price = minor units, confirmed by admin)
  phone      String
  comment    String?
  status     ApplicationStatus @default(NEW)
  // Operator-side pricing (mirrors Booking): the request has no route, so unitPrice
  // is set by hand (null = not quoted yet). total/paymentStatus recompute on edit.
  unitPrice     Int? // minor units, per-seat price; null = not quoted
  discount      Int           @default(0) // minor units
  prepaid       Int           @default(0) // minor units
  total         Int           @default(0) // minor units = (unitPrice ?? 0)*pax - discount + stops + addons
  paymentStatus PaymentStatus @default(UNPAID)
  addons        Json          @default("[]") // [{name, price}] — priced extra services (minor units)
  createdAt  DateTime          @default(now())

  @@index([status])
  @@index([createdAt])
}

/// Generic idempotency store powering the Idempotency-Key plugin.
model IdempotencyKey {
  key         String   @id
  endpoint    String
  requestHash String
  response    Json
  statusCode  Int      @default(200)
  createdAt   DateTime @default(now())
}

/// Singleton system settings (id is always "singleton").
model SystemConfig {
  id                   String       @id @default("singleton")
  currency             CurrencyCode @default(KGS)
  companyName          String       @default("EasyGo")
  whatsappPhone        String       @default("996700123456")
  locale               String       @default("ru-RU")
  telegramNotifyChatId String? // group chat for booking notifications (captured when bot is added)
  // Default per-stop prices shown to clients as a guideline (minor units).
  // The final price of every stop is still confirmed per booking by an admin.
  stopPriceCity        Int          @default(0) // точка в черте города
  stopPriceOutside     Int          @default(0) // точка за городом
  updatedAt            DateTime     @updatedAt
}
